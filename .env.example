# AI Travel Guide - Environment Variables
# Copy this file to .env and fill in your API keys

# LLM provider: openai | gemini | claude
VITE_LLM_PROVIDER=openai

# OpenAI API Key / model
# https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini

# Gemini API Key / model
# https://ai.google.dev/
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-2.0-flash

# Claude API Key / model
# https://console.anthropic.com/
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-3-5-sonnet-latest

# OpenWeatherMap API Key (for real-time weather data)
# https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Google Maps JavaScript API Key (for Places, Directions, Geocoding)
# https://console.cloud.google.com/apis/credentials
# Required APIs: Maps JavaScript API, Places API, Directions API, Geocoding API
VITE_GOOGLE_MAPS_API_KEY=
