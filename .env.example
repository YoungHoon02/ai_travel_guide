# AI Travel Guide - Environment Variables
# Copy this file to .env and fill in your API keys

# LLM provider: openai | gemini | claude
VITE_LLM_PROVIDER=

# OpenAI API Key / model
# https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=GPT-5.4 mini

# Gemini API Key / model
# 하이브리드 라우팅: parser + geography 는 Gemini cloud 로
VITE_GEMINI_API_KEY=
VITE_GEMINI_MODEL=gemini-3-flash-preview
VITE_PARSER_PROVIDER=gemini
VITE_PARSER_MODEL=gemini-2.5-flash-lite
VITE_GEOGRAPHY_PROVIDER=gemini
VITE_GEOGRAPHY_MODEL=gemini-2.5-flash-lite

# Claude API Key / model
# https://console.anthropic.com/
VITE_CLAUDE_API_KEY=
VITE_CLAUDE_MODEL=claude-3-5-sonnet-latest

# OpenWeatherMap API Key (for real-time weather data)
# https://openweathermap.org/api
VITE_OPENWEATHER_API_KEY=

# Google Maps JavaScript API Key (for Places, Directions, Geocoding)
# https://console.cloud.google.com/apis/credentials
# Required APIs (default path): Maps JavaScript API, Places API, Directions API, Geocoding API
# Optional (only when VITE_PREFER_ROUTES_API=true): Routes API
VITE_GOOGLE_MAPS_API_KEY=

# Prefer Google Routes API over JS DirectionsService (default: false)
# Keep false unless your key/project has Routes API enabled and billing configured.
VITE_PREFER_ROUTES_API=false

# Driving route traffic color segments from Routes API (green/yellow/red)
# Effective when VITE_PREFER_ROUTES_API=true and Routes API is enabled.
VITE_ROUTE_TRAFFIC_COLORS=true

# Legacy DirectionsService fallback (deprecated). Keep false unless you
# explicitly enabled legacy Directions API and want fallback behavior.
VITE_ALLOW_LEGACY_DIRECTIONS_FALLBACK=false

# Google Maps Map ID (optional)
# Enables google.maps.marker.AdvancedMarkerElement (replaces deprecated google.maps.Marker).
# Create a Map ID at: https://console.cloud.google.com/google/maps-apis/client-maps
# Note: inline dark-map styles are applied only when this is NOT set (cloud-based styling applies when set).
VITE_GOOGLE_MAPS_MAP_ID=

# Ollama (local LLM) — no API key needed
# VITE_LLM_PROVIDER=ollama
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=gemma4