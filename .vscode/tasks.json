			"label": "find-recheck-filtered",
			"type": "shell",
			"command": "git",
			"args": [
				"branch",
				"-a",
				"--list",
				"*recheck*"
			],
			"isBackground": false
		},
		{
			"label": "fetch-all",
			"type": "shell",
			"command": "git",
			"args": [
