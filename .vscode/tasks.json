		{
			"label": "check-current-branch",
			"type": "shell",
			"command": "git",
			"args": [
				"branch",
				"--show-current"
			],
			"isBackground": false
		},
		{
			"label": "checkout-recheck-api",
			"type": "shell",
			"command": "git",
			"args": [
